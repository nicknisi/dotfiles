#!/usr/bin/env bash

# Claude Code hook for tmux status integration
# Writes pane-level JSON status files for agent awareness
#
# Status file: ~/.cache/claude-status/{pane_num}.status
# Format: {"state":"...","pane":"%42","session":"name","tool":"Edit","ts":123}
#
# States:
#   working   - Claude is executing tools
#   waiting   - Claude finished, awaiting user input
#   completed - Claude just finished a task (decays to idle after 5s)
#   idle      - No active session

STATUS_DIR="$HOME/.cache/claude-status"
mkdir -p "$STATUS_DIR"

# Read Claude Code hook payload from stdin
INPUT=$(cat)

# Require tmux
[ -z "$TMUX" ] && exit 0

PANE_ID="${TMUX_PANE}"
[ -z "$PANE_ID" ] && exit 0

PANE_NUM="${PANE_ID#%}"
SESSION=$(tmux display-message -p '#{session_name}' 2>/dev/null)
[ -z "$SESSION" ] && exit 0

STATUS_FILE="$STATUS_DIR/${PANE_NUM}.status"
TS=$(date +%s)

# Extract tool_name from JSON payload (PreToolUse only)
TOOL=""
if [ "$1" = "PreToolUse" ]; then
  TOOL=$(echo "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null || echo "")
fi

write_status() {
  printf '{"state":"%s","pane":"%s","session":"%s","tool":"%s","ts":%s}\n' \
    "$1" "$PANE_ID" "$SESSION" "${2:-}" "$TS" > "$STATUS_FILE"
}

case "$1" in
  PreToolUse)        write_status "working" "$TOOL" ;;
  waiting)           write_status "waiting" ;;
  Stop|SubagentStop) write_status "completed" ;;
  SessionEnd)        rm -f "$STATUS_FILE" ;;
esac

exit 0
