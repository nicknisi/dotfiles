#!/usr/bin/env bash

# Jump to next waiting agent pane (cycles across all sessions)
# Scans both Claude and Pi status directories
#
# Usage: claude-next [--verify]
#   --verify  Use pane-detect to confirm status before switching
#
# Bind in tmux: bind-key n run-shell "claude-next"

CLAUDE_DIR="$HOME/.cache/claude-status"
PI_DIR="$HOME/.cache/pi-status"
VERIFY="${1:-}"
CURRENT_PANE=$(tmux display-message -p '#{pane_id}' 2>/dev/null)

waiting_panes=()

scan_dir() {
  local dir="$1"
  [ -d "$dir" ] || return
  for f in "$dir"/*.status; do
    [ -f "$f" ] || continue
    local state pane
    state=$(jq -r '.state // empty' "$f" 2>/dev/null)
    pane=$(jq -r '.pane // empty' "$f" 2>/dev/null)

    [ "$state" = "waiting" ] || continue
    [ -n "$pane" ] || continue

    # Verify pane exists (stale cleanup)
    if ! tmux display-message -t "$pane" -p '#{pane_id}' >/dev/null 2>&1; then
      rm -f "$f"
      continue
    fi

    # Optional: verify via pane output scraping
    if [ "$VERIFY" = "--verify" ]; then
      local detected
      detected=$(claude-pane-detect "$pane")
      [ "$detected" = "waiting" ] || continue
    fi

    waiting_panes+=("$pane")
  done
}

scan_dir "$CLAUDE_DIR"
scan_dir "$PI_DIR"

if [ ${#waiting_panes[@]} -eq 0 ]; then
  tmux display-message "No waiting agents"
  exit 0
fi

# Cycle: find next pane after current
target="${waiting_panes[0]}"
for i in "${!waiting_panes[@]}"; do
  if [ "${waiting_panes[$i]}" = "$CURRENT_PANE" ]; then
    next_idx=$(( (i + 1) % ${#waiting_panes[@]} ))
    target="${waiting_panes[$next_idx]}"
    break
  fi
done

tmux switch-client -t "$target" 2>/dev/null || \
  tmux display-message "Failed to switch to $target"
