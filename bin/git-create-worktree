#!/usr/bin/env bash

set -Eeuo pipefail
trap cleanup SIGINT SIGTERM ERR EXIT

setup_colors() {
  if [[ -t 2 ]] && [[ -z "${NO_COLOR-}" ]] && [[ "${TERM-}" != "dumb" ]]; then
    NOFORMAT='\033[0m' GRAY='\033[0;90m' RED='\033[0;31m' GREEN='\033[0;32m' ORANGE='\033[0;33m' BLUE='\033[0;34m' PURPLE='\033[0;35m' CYAN='\033[0;36m' YELLOW='\033[1;33m' BOLD='\033[1m' DIM='\033[2m'
  else
    NOFORMAT='' GRAY='' RED='' GREEN='' ORANGE='' BLUE='' PURPLE='' CYAN='' YELLOW='' BOLD='' DIM=''
  fi
}

msg() { echo >&2 -e "${1-}"; }
die() { msg "${RED}error:${NOFORMAT} $1"; exit "${2-1}"; }

cleanup() {
  trap - SIGINT SIGTERM ERR EXIT
  tput cnorm 2>/dev/null || true
}

spinner() {
  local LC_CTYPE=C
  local pid=$1
  local spin='⣾⣽⣻⢿⡿⣟⣯⣷'
  local charwidth=3
  local i=0
  tput civis 2>/dev/null || true
  while kill -0 "$pid" 2>/dev/null; do
    local i=$(((i + charwidth) % ${#spin}))
    printf >&2 "%s" "${spin:$i:$charwidth}"
    printf >&2 "\b"
    sleep .1
  done
  tput cnorm 2>/dev/null || true
  local exit_status=0
  wait "$pid" || exit_status=$?
  return $exit_status
}

run() {
  local message=$1; shift
  echo >&2 -ne "  ${GRAY}${message}${NOFORMAT} "
  "$@" &>/dev/null &
  if spinner $!; then
    echo >&2 -e "${GREEN}✓${NOFORMAT}"
  else
    echo >&2 -e "${RED}✗${NOFORMAT}"
    exit 1
  fi
}

usage() {
  cat <<EOF
${BOLD}Usage:${NOFORMAT} git create-worktree [options] <name>
       git create-worktree --pr <number>

Create a worktree with smart branch resolution.

${BOLD}Arguments:${NOFORMAT}
  <name>    Worktree directory name. Also used to resolve branches.

${BOLD}Options:${NOFORMAT}
  -p, --pr <number>       Create worktree from a GitHub PR
  -b, --branch <name>     Explicit branch name (skip auto-resolution)
  -B, --base <ref>        Base ref for new branches (default: origin/main)
  -P, --prefix <prefix>   Branch prefix for new branches (default: \$(git config github.user)/)
  -N, --no-upstream       Don't push/track an upstream branch
  -v, --verbose           Print debug info
  -h, --help              Show this help

${BOLD}Branch resolution order:${NOFORMAT}
  When given a <name>, the script tries (in order):
    1. Local branch matching <name> exactly
    2. Local branch matching <prefix><name>
    3. Remote branch matching <name> on origin
    4. Remote branch matching <prefix><name> on origin
    5. Creates a new branch <prefix><name> from --base

${BOLD}Examples:${NOFORMAT}
  git create-worktree my-feature          # new branch nicknisi/my-feature
  git create-worktree my-feature -b main  # worktree from existing 'main' branch
  git create-worktree --pr 143            # worktree from PR #143
  git create-worktree fix -B origin/v2    # new branch from v2
EOF
  exit
}

resolve_pr() {
  local pr_number=$1
  command -v gh &>/dev/null || die "gh CLI required for --pr flag"

  local pr_json
  pr_json=$(gh pr view "$pr_number" --json headRefName,state,title 2>/dev/null) \
    || die "could not find PR #${pr_number}"

  local pr_branch pr_state pr_title
  pr_branch=$(echo "$pr_json" | grep -o '"headRefName":"[^"]*"' | cut -d'"' -f4)
  pr_state=$(echo "$pr_json" | grep -o '"state":"[^"]*"' | cut -d'"' -f4)
  pr_title=$(echo "$pr_json" | grep -o '"title":"[^"]*"' | cut -d'"' -f4)

  [[ -z "$pr_branch" ]] && die "could not resolve branch for PR #${pr_number}"

  msg ""
  msg "  ${BLUE}PR #${pr_number}${NOFORMAT} ${BOLD}${pr_title}${NOFORMAT}"
  msg "  ${DIM}${pr_branch} · ${pr_state}${NOFORMAT}"
  msg ""

  echo "$pr_branch"
}

resolve_branch() {
  local name=$1
  local prefix=$2

  # 1. exact local branch
  if git show-ref --verify --quiet "refs/heads/${name}" 2>/dev/null; then
    msg "  ${GRAY}found local branch:${NOFORMAT} ${name}"
    echo "$name"
    return
  fi

  # 2. prefixed local branch
  if [[ "$name" != "${prefix}"* ]] && git show-ref --verify --quiet "refs/heads/${prefix}${name}" 2>/dev/null; then
    msg "  ${GRAY}found local branch:${NOFORMAT} ${prefix}${name}"
    echo "${prefix}${name}"
    return
  fi

  # 3. exact remote branch
  if git ls-remote --exit-code --heads origin "$name" &>/dev/null; then
    msg "  ${GRAY}found remote branch:${NOFORMAT} ${name}"
    run "fetching ${name}" git fetch origin "$name"
    echo "$name"
    return
  fi

  # 4. prefixed remote branch
  if [[ "$name" != "${prefix}"* ]] && git ls-remote --exit-code --heads origin "${prefix}${name}" &>/dev/null; then
    msg "  ${GRAY}found remote branch:${NOFORMAT} ${prefix}${name}"
    run "fetching ${prefix}${name}" git fetch origin "${prefix}${name}"
    echo "${prefix}${name}"
    return
  fi

  # 5. nothing found — will create new
  echo ""
}

dir_from_branch() {
  local branch=$1
  # strip common prefixes to get a clean directory name
  echo "$branch" | sed -E 's|^[^/]+/||'
}

# -- parse args --
create_upstream=1
prefix="$(git config github.user 2>/dev/null || echo "")/"
base='origin/main'
branch=''
pr_number=''
worktree=''

positional=()
while [[ $# -gt 0 ]]; do
  case "$1" in
  -h | --help) setup_colors; usage ;;
  -v | --verbose) set -x ;;
  --no-color) NO_COLOR=1 ;;
  -N | --no-upstream) create_upstream=0 ;;
  -p | --pr)
    pr_number="${2-}"
    [[ -z "$pr_number" ]] && die "--pr requires a PR number"
    shift
    ;;
  -b | --branch)
    branch="${2-}"
    [[ -z "$branch" ]] && die "--branch requires a branch name"
    shift
    ;;
  -B | --base)
    base="${2-}"
    shift
    ;;
  -P | --prefix)
    prefix="${2-}"
    shift
    ;;
  --)
    shift
    positional+=("$@")
    break
    ;;
  -?*) die "unknown option: $1" ;;
  *) positional+=("$1") ;;
  esac
  shift
done
set -- "${positional[@]}"

setup_colors

msg ""
msg "${BOLD}Creating worktree${NOFORMAT}"

# -- resolve what we're checking out --
if [[ -n "$pr_number" ]]; then
  branch=$(resolve_pr "$pr_number")
  worktree="${1:-$(dir_from_branch "$branch")}"
elif [[ -n "$branch" ]]; then
  worktree="${1:-$(dir_from_branch "$branch")}"
  # -b means "use this exact branch" — check local, then remote, then it's new
  if git show-ref --verify --quiet "refs/heads/${branch}" 2>/dev/null; then
    msg "  ${GRAY}found local branch:${NOFORMAT} ${branch}"
  elif git ls-remote --exit-code --heads origin "$branch" &>/dev/null; then
    msg "  ${GRAY}found remote branch:${NOFORMAT} ${branch}"
    run "fetching ${branch}" git fetch origin "$branch"
  else
    msg "  ${GRAY}creating new branch:${NOFORMAT} ${branch}"
  fi
else
  [[ $# -eq 0 ]] && die "missing argument: <name> or --pr <number>\n\n  Run 'git create-worktree --help' for usage."
  worktree="$1"

  resolved=$(resolve_branch "$worktree" "$prefix")
  if [[ -n "$resolved" ]]; then
    branch="$resolved"
  else
    branch="${prefix}${worktree}"
    msg "  ${GRAY}creating new branch:${NOFORMAT} ${branch}"
  fi
fi

# -- check for conflicts --
if [[ -d "$worktree" ]]; then
  die "directory '${worktree}' already exists"
fi

# -- create worktree --
if git show-ref --verify --quiet "refs/heads/${branch}" 2>/dev/null; then
  run "creating worktree from ${branch}" git worktree add "$worktree" "$branch"
else
  git fetch origin "$branch" 2>/dev/null && \
    run "creating worktree from origin/${branch}" git worktree add "$worktree" -b "$branch" "origin/${branch}" || \
    run "creating worktree (new branch from ${base})" git worktree add -b "$branch" "$worktree" "$base"
fi

# -- set up upstream --
if [[ $create_upstream -eq 1 ]]; then
  cd "$worktree"
  if git ls-remote --exit-code --heads origin "$branch" &>/dev/null; then
    run "tracking origin/${branch}" git branch --set-upstream-to="origin/$branch"
  else
    run "pushing ${branch} to origin" git push -u origin "$branch"
  fi
  cd ..
fi

msg ""
msg "  ${GREEN}✓${NOFORMAT} ${BOLD}${worktree}${NOFORMAT} → ${CYAN}${branch}${NOFORMAT}"
msg "  ${DIM}cd ${worktree}${NOFORMAT}"
msg ""
