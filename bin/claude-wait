#!/usr/bin/env bash
# Block until a pane reaches a target state
# Usage: claude-wait <pane_id> --state <state>[,state2] [--timeout <seconds>] [--poll <seconds>]
#
# Exit codes:
#   0 — target state reached
#   1 — timeout
#   2 — pane not found / died mid-wait / invalid args

. agent-status-lib

PANE_ID=""
TARGET_STATES=""
TIMEOUT=0       # 0 = no timeout (wait forever)
POLL_INTERVAL=2

while [ $# -gt 0 ]; do
  case "$1" in
    --state)   TARGET_STATES="$2"; shift 2 ;;
    --timeout) TIMEOUT="$2"; shift 2 ;;
    --poll)    POLL_INTERVAL="$2"; shift 2 ;;
    -*)        echo "Unknown flag: $1" >&2; exit 2 ;;
    *)         PANE_ID="$1"; shift ;;
  esac
done

[ -z "$PANE_ID" ] && { echo "Usage: claude-wait <pane_id> --state <states> [--timeout N]" >&2; exit 2; }
[ -z "$TARGET_STATES" ] && { echo "Missing --state" >&2; exit 2; }

# Parse comma-separated states into array
IFS=',' read -ra STATES <<< "$TARGET_STATES"

START=$(date +%s)

while true; do
  # Check if pane still exists (display-message returns empty for dead panes)
  pane_check=$(tmux display-message -t "$PANE_ID" -p '#{pane_id}' 2>/dev/null)
  if [ -z "$pane_check" ]; then
    echo "Pane $PANE_ID no longer exists" >&2
    exit 2
  fi

  # Find status file for this pane
  status_file=$(agent_find_status "$PANE_ID")

  if [ -n "$status_file" ]; then
    now=$(date +%s)
    state=$(jq -r '.state // "idle"' "$status_file" 2>/dev/null)
    ts=$(jq -r '.ts // 0' "$status_file" 2>/dev/null)
    effective=$(agent_effective_state "$state" "$ts" "$now")

    for target in "${STATES[@]}"; do
      if [ "$effective" = "$target" ]; then
        echo "$PANE_ID reached $effective"
        exit 0
      fi
    done
  fi

  # Check timeout
  if [ "$TIMEOUT" -gt 0 ] 2>/dev/null; then
    elapsed=$(( $(date +%s) - START ))
    if [ "$elapsed" -ge "$TIMEOUT" ]; then
      echo "Timeout after ${elapsed}s waiting for $PANE_ID to reach $TARGET_STATES" >&2
      exit 1
    fi
  fi

  sleep "$POLL_INTERVAL"
done
