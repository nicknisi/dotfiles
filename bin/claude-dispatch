#!/usr/bin/env bash
# Dispatch agent work to a new tmux pane
# Usage: claude-dispatch [options] <prompt>
#
# Options:
#   --worktree     Create a git worktree for isolation
#   --session NAME Target session (default: current)
#   --agent CMD    Agent command (default: claude)
#   --vertical     Split vertically instead of horizontally
#
# Auto-detects:
#   - Current session and working directory
#   - Git repository root
#   - Creates new pane in current window

. agent-status-lib

# Defaults
WORKTREE=false
SESSION=""
AGENT_CMD="claude"
SPLIT_DIR="-h"  # horizontal split
PROMPT=""

while [ $# -gt 0 ]; do
  case "$1" in
    --worktree)  WORKTREE=true; shift ;;
    --session)   SESSION="$2"; shift 2 ;;
    --agent)     AGENT_CMD="$2"; shift 2 ;;
    --vertical)  SPLIT_DIR="-v"; shift ;;
    -*)          echo "Unknown flag: $1" >&2; exit 1 ;;
    *)           PROMPT="$*"; break ;;
  esac
done

[ -z "$PROMPT" ] && { echo "Usage: claude-dispatch [options] <prompt>" >&2; exit 1; }

# Auto-detect context
SESSION="${SESSION:-$(tmux display-message -p '#{session_name}' 2>/dev/null)}"
WORK_DIR=$(tmux display-message -p '#{pane_current_path}' 2>/dev/null)
[ -z "$WORK_DIR" ] && WORK_DIR="$PWD"

# Find git root
GIT_ROOT=$(git -C "$WORK_DIR" rev-parse --show-toplevel 2>/dev/null)

# Handle worktree creation
LAUNCH_DIR="$WORK_DIR"
WORKTREE_BRANCH=""
if $WORKTREE && [ -n "$GIT_ROOT" ]; then
  # Generate branch name from prompt (first 30 chars, kebab-case)
  WORKTREE_BRANCH="agent/$(echo "$PROMPT" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' '-' | head -c 30 | sed 's/-$//')"
  WORKTREE_DIR="${GIT_ROOT}/.worktrees/$(basename "$WORKTREE_BRANCH")"

  # Create worktree
  if git -C "$GIT_ROOT" worktree add -b "$WORKTREE_BRANCH" "$WORKTREE_DIR" 2>/dev/null; then
    LAUNCH_DIR="$WORKTREE_DIR"
    echo "Created worktree: $WORKTREE_DIR ($WORKTREE_BRANCH)"
  else
    echo "Warning: worktree creation failed, using current directory" >&2
    WORKTREE=false
  fi
fi

# Build agent command
# Escape prompt for shell — use single quotes with internal quote escaping
ESCAPED_PROMPT=$(printf '%s' "$PROMPT" | sed "s/'/'\\\\''/g")
CMD="cd '$LAUNCH_DIR' && $AGENT_CMD -p '$ESCAPED_PROMPT'"

# Create new pane and run command
NEW_PANE=$(tmux split-window $SPLIT_DIR -t "$SESSION" -P -F '#{pane_id}' "$CMD" 2>/dev/null)

if [ -n "$NEW_PANE" ]; then
  echo "Dispatched to $NEW_PANE in $SESSION"
  [ -n "$WORKTREE_BRANCH" ] && echo "Worktree: $WORKTREE_DIR (branch: $WORKTREE_BRANCH)"
  echo "Prompt: $PROMPT"
  # Output pane ID for scripting
  echo "$NEW_PANE"
else
  echo "Failed to create pane" >&2
  exit 1
fi
