#!/usr/bin/env bash

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[0;37m'
DIM='\033[2m'
RESET='\033[0m'

# Separator (minimal style)
SEP="${DIM}│${RESET}"

# Emoji icons
ICON_PROJECT="📁"
ICON_BRANCH="🌿"
ICON_CONTEXT="📊"
ICON_COST="💰"
ICON_STYLE="🎨"
ICON_USAGE="⚡"

# Feature flags (set env vars to 0 to disable)
SHOW_CONTEXT_TOKENS="${CLAUDE_STATUSLINE_TOKENS:-1}"
SHOW_USAGE="${CLAUDE_STATUSLINE_USAGE:-1}"

# Usage limits config
USAGE_CACHE_TTL="${CLAUDE_STATUSLINE_USAGE_TTL:-120}"
USAGE_CACHE_DIR="${TMPDIR:-/tmp}/claude-statusline-cache"

# Read JSON input from stdin
input=$(cat)

# Helper functions for extracting data
get_model_name() { echo "$input" | jq -r '.model.display_name // "Unknown Model"'; }

# Get model-specific icon based on model name
get_model_icon() {
  local model_name=$(get_model_name)
  case "$model_name" in
  *[Oo]pus*) echo "🎭" ;;   # Theater masks for the dramatic, powerful model
  *[Ss]onnet*) echo "🎵" ;; # Musical note for the balanced, harmonious model
  *[Hh]aiku*) echo "🍃" ;;  # Leaf for the light, quick model
  *) echo "🧠" ;;           # Default brain icon
  esac
}
get_output_style() { echo "$input" | jq -r '.output_style.name // "default"'; }
get_current_dir() { echo "$input" | jq -r '.workspace.current_dir // "."'; }
get_project_dir() { echo "$input" | jq -r '.workspace.project_dir // "."'; }
get_cost() {
  local cost=$(echo "$input" | jq -r '.cost.total_cost_usd // 0')
  printf "\$%.2f" "$cost"
}

get_context_percent() {
  # Use pre-calculated percentage from Claude Code (recommended approach)
  local percent=$(echo "$input" | jq -r '.context_window.used_percentage // 0')
  # Round to integer for display
  printf "%.0f" "$percent"
}

get_context_used() {
  # Calculate tokens from percentage and window size (most accurate)
  local percent=$(echo "$input" | jq -r '.context_window.used_percentage // 0')
  local window=$(echo "$input" | jq -r '.context_window.context_window_size // 200000')
  local used=$(echo "$percent * $window / 100" | bc)
  if [ "$used" -ge 1000 ]; then
    printf "%.0fK" "$(echo "scale=0; $used / 1000" | bc)"
  else
    printf "%d" "$used"
  fi
}

# Build a progress bar with color based on percentage
build_context_bar() {
  local percent=$(get_context_percent)
  local bar_width=10
  local filled=$((percent * bar_width / 100))
  local empty=$((bar_width - filled))

  # Cap filled at bar_width
  if [ "$filled" -gt "$bar_width" ]; then
    filled=$bar_width
    empty=0
  fi

  # Choose color based on percentage thresholds
  local bar_color
  if [ "$percent" -lt 40 ]; then
    bar_color="$WHITE"
  elif [ "$percent" -lt 80 ]; then
    bar_color="$YELLOW"
  else
    bar_color="$RED"
  fi

  # Build the bar
  local bar=""
  for ((i = 0; i < filled; i++)); do
    bar+="█"
  done
  for ((i = 0; i < empty; i++)); do
    bar+="░"
  done

  if [ "$SHOW_CONTEXT_TOKENS" = "1" ]; then
    local used=$(get_context_used)
    printf "%s%s%s %d%% ${DIM}(%s)${RESET}" "$bar_color" "$bar" "$RESET" "$percent" "$used"
  else
    printf "%s%s%s %d%%" "$bar_color" "$bar" "$RESET" "$percent"
  fi
}

# ── Usage limits ──────────────────────────────────────────────────────────────

get_oauth_token() {
  local creds
  creds=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null) || return 1
  echo "$creds" | jq -r '.claudeAiOauth.accessToken // empty'
}

# Format ISO 8601 timestamp to human-readable time-until string
format_time_until() {
  local resets_at="$1"
  [ -z "$resets_at" ] && echo "?" && return

  local reset_epoch
  # Normalize: strip +00:00 → Z, strip fractional seconds (.943648)
  local normalized="${resets_at/+00:00/Z}"
  normalized=$(echo "$normalized" | sed 's/\.[0-9]*Z/Z/')
  reset_epoch=$(date -u -jf "%Y-%m-%dT%H:%M:%SZ" "$normalized" "+%s" 2>/dev/null) \
    || { echo "?"; return; }

  local now
  now=$(date "+%s")
  if [ "$now" -ge "$reset_epoch" ]; then
    echo "now"
    return
  fi

  local secs=$((reset_epoch - now))
  local mins=$((secs / 60))
  local hours=$((mins / 60))
  local days=$((hours / 24))

  if [ "$days" -gt 0 ]; then
    printf "%dd%dh" "$days" $((hours % 24))
  elif [ "$hours" -gt 0 ]; then
    printf "%dh%dm" "$hours" $((mins % 60))
  else
    printf "%dm" "$mins"
  fi
}

# Read cached usage data if fresh enough
read_usage_cache() {
  local cache_file="${USAGE_CACHE_DIR}/usage.json"
  [ -f "$cache_file" ] || return 1

  local file_age
  local file_mod
  file_mod=$(stat -f "%m" "$cache_file" 2>/dev/null) || return 1
  local now
  now=$(date "+%s")
  file_age=$((now - file_mod))

  [ "$file_age" -lt "$USAGE_CACHE_TTL" ] || return 1
  cat "$cache_file"
}

# Fetch usage from API and write to cache
fetch_usage() {
  local token
  token=$(get_oauth_token) || return 1
  [ -n "$token" ] || return 1

  mkdir -p "$USAGE_CACHE_DIR"

  local response
  response=$(curl -s --max-time 3 \
    -H "Authorization: Bearer $token" \
    -H "anthropic-beta: oauth-2025-04-20" \
    "https://api.anthropic.com/api/oauth/usage" 2>/dev/null) || return 1

  # Validate response has expected fields
  echo "$response" | jq -e '.five_hour.utilization' >/dev/null 2>&1 || return 1

  echo "$response" > "${USAGE_CACHE_DIR}/usage.json"
  echo "$response"
}

# Get usage data (cache-first, then fetch)
get_usage_data() {
  local data
  data=$(read_usage_cache) && echo "$data" && return
  fetch_usage
}

# Build a mini usage bar for a single window
# Args: $1=remaining_pct (0-100), $2=label ("5h"/"7d"), $3=time_until
build_usage_bar() {
  local remaining="$1" label="$2" time_until="$3"
  local bar_width=5
  local filled=$((remaining * bar_width / 100))
  local empty=$((bar_width - filled))

  [ "$filled" -gt "$bar_width" ] && filled=$bar_width && empty=0
  [ "$filled" -lt 0 ] && filled=0 && empty=$bar_width

  local bar_color
  if [ "$remaining" -gt 50 ]; then
    bar_color="$GREEN"
  elif [ "$remaining" -gt 20 ]; then
    bar_color="$YELLOW"
  else
    bar_color="$RED"
  fi

  local bar=""
  for ((i = 0; i < filled; i++)); do bar+="━"; done
  for ((i = 0; i < empty; i++)); do bar+="╌"; done

  printf "${DIM}%s${RESET} %s%s%s %d%% ${DIM}↻%s${RESET}" \
    "$label" "$bar_color" "$bar" "$RESET" "$remaining" "$time_until"
}

# Build usage display string
build_usage_display() {
  [ "$SHOW_USAGE" = "1" ] || return

  local data
  data=$(get_usage_data) || return

  local five_used seven_used five_reset seven_reset
  five_used=$(echo "$data" | jq -r '.five_hour.utilization // 0' | xargs printf "%.0f")
  seven_used=$(echo "$data" | jq -r '.seven_day.utilization // 0' | xargs printf "%.0f")
  five_reset=$(echo "$data" | jq -r '.five_hour.resets_at // empty')
  seven_reset=$(echo "$data" | jq -r '.seven_day.resets_at // empty')

  local five_remaining=$((100 - five_used))
  local seven_remaining=$((100 - seven_used))

  local five_until seven_until
  five_until=$(format_time_until "$five_reset")
  seven_until=$(format_time_until "$seven_reset")

  local five_bar seven_bar
  five_bar=$(build_usage_bar "$five_remaining" "5h" "$five_until")
  seven_bar=$(build_usage_bar "$seven_remaining" "7d" "$seven_until")

  printf "%s ${DIM}╱${RESET} %s" "$five_bar" "$seven_bar"
}

# Extract values
model=$(get_model_name)
model_icon=$(get_model_icon)
output_style=$(get_output_style)
current_dir=$(get_current_dir)
project_dir=$(get_project_dir)
cost_display=$(get_cost)
context_bar=$(build_context_bar)
usage_display=$(build_usage_display)

# Get project name and handle subdirectory display
project=$(basename "$project_dir")
if [ "$current_dir" != "$project_dir" ]; then
  subdir=$(basename "$current_dir")
  project="${project} (CWD: ${subdir}/)"
fi

# Get git branch
git_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "no-git")

# Build statusline (order: project → branch → context → model → cost → style)
statusline=""
statusline+="${ICON_PROJECT} ${BLUE}${project}${RESET}"
statusline+=" ${SEP} "
statusline+="${ICON_BRANCH} ${GREEN}${git_branch}${RESET}"
statusline+=" ${SEP} "
statusline+="${ICON_CONTEXT} ${context_bar}"
statusline+=" ${SEP} "
statusline+="${model_icon} ${MAGENTA}${model}${RESET}"
statusline+=" ${SEP} "
statusline+="${ICON_COST} ${CYAN}${cost_display}${RESET}"
if [ -n "$usage_display" ]; then
  statusline+=" ${SEP} "
  statusline+="${ICON_USAGE} ${usage_display}"
fi
if [ "$output_style" != "default" ]; then
  statusline+=" ${SEP} "
  statusline+="${ICON_STYLE} ${DIM}${output_style}${RESET}"
fi

echo -e "$statusline"
