#!/usr/bin/env bash
# Agent status shared library — source with: . agent-status-lib

AGENT_STATUS_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/agent-status/agents.conf"
AGENT_WORKING_TIMEOUT=180   # 3 minutes
AGENT_COMPLETED_DECAY=5     # 5 seconds

# List all registered status directories (one per line)
agent_status_dirs() {
  if [ -f "$AGENT_STATUS_CONFIG" ]; then
    while IFS='=' read -r name dir; do
      [[ "$name" =~ ^[[:space:]]*# ]] && continue
      [ -z "$name" ] && continue
      dir="${dir/#\$HOME/$HOME}"
      [ -d "$dir" ] && echo "$dir"
    done < "$AGENT_STATUS_CONFIG"
  else
    [ -d "$HOME/.cache/claude-status" ] && echo "$HOME/.cache/claude-status"
    [ -d "$HOME/.cache/pi-status" ] && echo "$HOME/.cache/pi-status"
  fi
}

# Compute effective state after decay/timeout
# Args: state ts now
agent_effective_state() {
  local state="$1" ts="$2" now="$3"
  local age=0
  [ "$ts" -gt 0 ] 2>/dev/null && age=$((now - ts))
  case "$state" in
    completed) [ "$age" -ge "$AGENT_COMPLETED_DECAY" ] && { echo "idle"; return; } ;;
    working)   [ "$age" -ge "$AGENT_WORKING_TIMEOUT" ] && { echo "stale"; return; } ;;
  esac
  echo "$state"
}

# Check if a status file represents an unseen terminal state
# Args: status_file
# Returns: 0 if unseen, 1 if seen
agent_is_unseen() {
  local file="$1"
  local state ts seen_ts
  state=$(jq -r '.state // "idle"' "$file" 2>/dev/null)
  ts=$(jq -r '.ts // 0' "$file" 2>/dev/null)
  seen_ts=$(jq -r '.seen_ts // 0' "$file" 2>/dev/null)
  case "$state" in
    waiting|completed)
      [ "$seen_ts" -lt "$ts" ] 2>/dev/null && return 0 ;;
  esac
  return 1
}

# Mark a status file as seen (write seen_ts)
# Args: status_file
agent_mark_seen() {
  local file="$1"
  [ -f "$file" ] || return
  local now
  now=$(date +%s)
  local tmp
  tmp=$(jq --argjson s "$now" '.seen_ts = $s' "$file" 2>/dev/null) || return
  [ -n "$tmp" ] && printf '%s\n' "$tmp" > "$file"
}

# Cached tmux server PID (one lookup per script invocation)
_AGENT_TMUX_SERVER_PID=""
agent_tmux_server_pid() {
  [ -n "$_AGENT_TMUX_SERVER_PID" ] && { echo "$_AGENT_TMUX_SERVER_PID"; return; }
  _AGENT_TMUX_SERVER_PID=$(tmux display-message -p '#{pid}' 2>/dev/null)
  echo "$_AGENT_TMUX_SERVER_PID"
}

# Validate a status file's pane is still the same pane (not a reused ID)
# Returns 0 if valid, 1 if stale (removes the file as side effect)
# Args: file pane session [tmux_pid_from_file]
agent_validate_pane() {
  local file="$1" pane="$2" session="$3" file_tmux_pid="${4:-}"

  # Pane must still exist (check output, not exit code — tmux 3.6+ returns 0 for dead panes)
  local pane_check
  pane_check=$(tmux display-message -t "$pane" -p '#{pane_id}' 2>/dev/null)
  if [ -z "$pane_check" ]; then
    rm -f "$file"; return 1
  fi

  # If file stores the tmux server PID, compare it — catches reboot/restart
  if [ -n "$file_tmux_pid" ]; then
    local cur
    cur=$(agent_tmux_server_pid)
    if [ -n "$cur" ] && [ "$file_tmux_pid" != "$cur" ]; then
      rm -f "$file"; return 1
    fi
    return 0
  fi

  # Fallback for old files without tmux_pid: session name must match
  local actual
  actual=$(tmux display-message -t "$pane" -p '#{session_name}' 2>/dev/null)
  if [ -n "$actual" ] && [ "$actual" != "$session" ]; then
    rm -f "$file"; return 1
  fi
  return 0
}

# Find status file for a given pane ID across all dirs
# Args: pane_id (e.g., %121)
agent_find_status() {
  local pane_id="$1"
  local pane_num="${pane_id#%}"
  local dir
  while IFS= read -r dir; do
    local f="$dir/${pane_num}.status"
    [ -f "$f" ] && { echo "$f"; return 0; }
  done < <(agent_status_dirs)
  return 1
}
