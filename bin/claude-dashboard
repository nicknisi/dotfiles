#!/usr/bin/env bash

# Agent-aware tmux session/pane dashboard
# Shows agent panes grouped by status with project path, tool info, and elapsed time
# Live pane preview on selection, Ctrl-R to refresh
#
# Keybindings:
#   Enter    вЂ” switch to selected pane/session
#   Ctrl-R   вЂ” refresh listing
#   Ctrl-N   вЂ” jump to next waiting agent (without closing dashboard)
#   Esc/q    вЂ” cancel

. agent-status-lib

format_elapsed() {
  local secs=$1
  if [ "$secs" -lt 5 ]; then
    echo "now"
  elif [ "$secs" -lt 60 ]; then
    echo "${secs}s"
  elif [ "$secs" -lt 3600 ]; then
    echo "$(( secs / 60 ))m"
  elif [ "$secs" -lt 86400 ]; then
    echo "$(( secs / 3600 ))h"
  else
    echo "$(( secs / 86400 ))d"
  fi
}

pane_location() {
  local pane="$1" session="$2"
  local path
  path=$(tmux display-message -t "$pane" -p '#{pane_current_path}' 2>/dev/null)
  [ -z "$path" ] && return

  local short="${path/#$HOME\//}"
  short="${short/#Developer\//}"
  [ "$short" = "$session" ] && return
  echo "$short"
}

declare -A _git_cache

pane_git_branch() {
  local pane="$1"
  local path
  path=$(tmux display-message -t "$pane" -p '#{pane_current_path}' 2>/dev/null)
  [ -z "$path" ] && return
  [ -n "${_git_cache[$path]+x}" ] && { echo "${_git_cache[$path]}"; return; }
  local branch
  branch=$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null)
  _git_cache[$path]="${branch:-}"
  [ -n "$branch" ] && echo "$branch"
}

format_ports() {
  local raw="$1"
  [ -z "$raw" ] && return
  local first="${raw%%,*}"
  local rest="${raw#*,}"
  if [ "$rest" = "$raw" ]; then
    echo "вЊЃ${first}"
  else
    local count=1
    local tmp="$rest"
    while [ "$tmp" != "${tmp#*,}" ]; do count=$((count + 1)); tmp="${tmp#*,}"; done
    count=$((count + 1))
    echo "вЊЃ${first}+${count}"
  fi
}

show_preview() {
  local line="$1"
  # Pane ID is the first tab-separated field
  local pane_id="${line%%	*}"

  if [ -n "$pane_id" ] && [[ "$pane_id" == %* ]]; then
    echo -e "\033[1mв”Ђв”Ђ Pane $pane_id в”Ђв”Ђ\033[0m"
    echo
    tmux capture-pane -p -t "$pane_id" -S -25 2>/dev/null
  else
    local session
    session=$(echo "$line" | awk -F'\t' '{print $2}' | awk '{print $1}')
    [ -z "$session" ] && return
    echo -e "\033[1mв”Ђв”Ђ $session в”Ђв”Ђ\033[0m"
    echo
    tmux list-windows -t "$session" -F "  #{window_index}: #{window_name}  #{pane_current_path}" 2>/dev/null
  fi
}

generate_listing() {
  local now
  now=$(date +%s)

  local CURRENT_PANE
  CURRENT_PANE=$(tmux display-message -p '#{pane_id}' 2>/dev/null)

  local current_line=""
  local waiting=()
  local working=()
  local completed=()
  local stale_lines=()
  local idle=()
  local agent_sessions=()
  local w_count=0 a_count=0 c_count=0 s_count=0 i_count=0

  declare -A _pane_ports
  while read -r p port; do
    _pane_ports[$p]="${_pane_ports[$p]:+${_pane_ports[$p]},}$port"
  done < <(claude-ports 2>/dev/null)

  while IFS= read -r dir; do
    [ -d "$dir" ] || continue
    for f in "$dir"/*.status; do
      [ -f "$f" ] || continue

      local state pane session tool ts tmux_pid
      state=$(jq -r '.state // "idle"' "$f" 2>/dev/null) || continue
      pane=$(jq -r '.pane // empty' "$f" 2>/dev/null)
      session=$(jq -r '.session // empty' "$f" 2>/dev/null)
      tool=$(jq -r '.tool // empty' "$f" 2>/dev/null)
      ts=$(jq -r '.ts // 0' "$f" 2>/dev/null)
      tmux_pid=$(jq -r '.tmux_pid // empty' "$f" 2>/dev/null)

      [ -n "$pane" ] || continue
      [ -n "$session" ] || continue

      agent_validate_pane "$f" "$pane" "$session" "$tmux_pid" || continue

      agent_sessions+=("$session")

      local location
      location=$(pane_location "$pane" "$session")

      local elapsed=""
      if [ "$ts" -gt 0 ] 2>/dev/null; then
        local diff=$((now - ts))
        [ "$diff" -ge 0 ] && elapsed=$(format_elapsed "$diff")
      fi

      state=$(agent_effective_state "$state" "${ts:-0}" "$now")

      # Build detail: location В· branch В· ports
      local detail=""
      [ -n "$location" ] && detail="$location"

      local git_branch
      git_branch=$(pane_git_branch "$pane")
      if [ -n "$git_branch" ] && [ "$git_branch" != "main" ] && [ "$git_branch" != "master" ]; then
        detail="${detail:+$detail В· }${git_branch:0:20}"
      fi

      local ports="${_pane_ports[$pane]:-}"
      if [ -n "$ports" ]; then
        local port_hint
        port_hint=$(format_ports "$ports")
        detail="${detail:+$detail В· }$port_hint"
      fi

      detail="${detail:0:48}"

      local is_current=false
      [ "$pane" = "$CURRENT_PANE" ] && is_current=true

      # Uniform format: pane_id<TAB> в–Њ session detail elapsed
      # State = bar color + text color. No variable-width prefixes.
      local bar_color detail_color elapsed_color
      case "$state" in
        waiting)   w_count=$((w_count + 1)); bar_color="1;33"; detail_color="33"; elapsed_color="1;33" ;;
        completed) c_count=$((c_count + 1)); bar_color="1;32"; detail_color="32"; elapsed_color="32"; [ -z "$detail" ] && detail="done" ;;
        working)   a_count=$((a_count + 1)); bar_color="38;5;208"; detail_color="2"; elapsed_color="2" ;;
        stale)     s_count=$((s_count + 1)); bar_color="2;33"; detail_color="2;33"; elapsed_color="2;33"; [ -z "$detail" ] && detail="stale" ;;
        *)         i_count=$((i_count + 1)); bar_color="2"; detail_color="2"; elapsed_color="2" ;;
      esac

      local line
      if $is_current; then
        line=$(printf "%s\t\033[${bar_color}mв–Њ\033[0m \033[1m%-14s\033[0m %-48s %4s" \
          "$pane" "$session" "$detail" "$elapsed")
      else
        line=$(printf "%s\t\033[${bar_color}mв–Њ\033[0m %-14s \033[${detail_color}m%-48s\033[0m \033[${elapsed_color}m%4s\033[0m" \
          "$pane" "$session" "$detail" "$elapsed")
      fi

      case "$state" in
        waiting)   $is_current && current_line="$line" || waiting+=("$line") ;;
        completed) $is_current && current_line="$line" || completed+=("$line") ;;
        working)   $is_current && current_line="$line" || working+=("$line") ;;
        stale)     $is_current && current_line="$line" || stale_lines+=("$line") ;;
        *)         $is_current && current_line="$line" || idle+=("$line") ;;
      esac
    done
  done < <(agent_status_dirs)

  # Summary line
  local summary=""
  [ "$w_count" -gt 0 ] && summary+="\033[1;33m${w_count} waiting\033[0m  "
  [ "$c_count" -gt 0 ] && summary+="\033[1;32m${c_count} done\033[0m  "
  [ "$a_count" -gt 0 ] && summary+="\033[38;5;208m${a_count} working\033[0m  "
  [ "$s_count" -gt 0 ] && summary+="\033[2;33m${s_count} stale\033[0m  "
  [ "$i_count" -gt 0 ] && summary+="\033[2m${i_count} idle\033[0m  "
  if [ -n "$summary" ]; then
    echo -e "\t$summary"
    printf '\t\033[2m  %-14s %-48s %4s\033[0m\n' "SESSION" "DETAIL" "AGE"
    echo -e "\t\033[2mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
  fi

  # Current pane first (bold session name = "you are here")
  [ -n "$current_line" ] && echo -e "$current_line"

  # Agent panes: waiting в†’ completed в†’ working в†’ stale в†’ idle
  for l in "${waiting[@]}"; do echo -e "$l"; done
  for l in "${completed[@]}"; do echo -e "$l"; done
  for l in "${working[@]}"; do echo -e "$l"; done
  for l in "${stale_lines[@]}"; do echo -e "$l"; done
  for l in "${idle[@]}"; do echo -e "$l"; done

  # Non-agent sessions
  local no_agent=()
  while IFS=: read -r name windows attached; do
    local has_agent=false
    for s in "${agent_sessions[@]}"; do
      [ "$s" = "$name" ] && { has_agent=true; break; }
    done
    $has_agent && continue

    no_agent+=("$(printf "\t\033[2mв–Њ %-14s %-48s %4s\033[0m" "$name" "" "${windows}w")")
  done < <(tmux list-sessions -F "#{session_name}:#{session_windows}:#{?session_attached,(attached),}" 2>/dev/null)

  if [ ${#no_agent[@]} -gt 0 ]; then
    [ "$((w_count + c_count + a_count + s_count + i_count))" -gt 0 ] && echo -e "\t\033[2mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
    for l in "${no_agent[@]}"; do echo -e "$l"; done
  fi
}

# Self-invocation modes
case "${1:-}" in
  --generate)
    generate_listing
    exit 0
    ;;
  --preview)
    shift
    show_preview "$*"
    exit 0
    ;;
esac

SELF=$(realpath "$0")

selected=$(generate_listing | fzf \
  --ansi \
  --no-sort \
  --delimiter='\t' \
  --with-nth=2.. \
  --header-lines=3 \
  --header="enter: switch В· ctrl-p: preview В· ctrl-r: refresh В· ctrl-n: next waiting В· esc: cancel" \
  --prompt="  " \
  --pointer="в–¶" \
  --preview="$SELF --preview {}" \
  --preview-window="right:45%:wrap:hidden" \
  --bind="ctrl-p:toggle-preview" \
  --bind="ctrl-r:reload($SELF --generate)" \
  --bind="ctrl-n:execute-silent(claude-next)+abort" \
  --bind="j:down,k:up,q:cancel" \
  --layout=reverse \
  --info=inline \
  --margin=0 \
  --padding=0)

if [ -n "$selected" ]; then
  # Skip separator/summary lines (no pane ID in first field)
  echo "$selected" | grep -qE 'в”Ђв”Ђв”Ђв”Ђ| waiting| working| idle| done' && exit 0

  # Pane ID is the first tab-separated field
  pane_id="${selected%%	*}"

  if [ -n "$pane_id" ] && [[ "$pane_id" == %* ]]; then
    tmux switch-client -t "$pane_id" 2>/dev/null
  else
    # Non-agent session вЂ” smart switch
    session_name=$(echo "$selected" | awk -F'\t' '{print $2}' | awk '{for(i=1;i<=NF;i++){if($i!="в–Њ"&&$i!="В·"&&$i!=""){print $i;exit}}}')
    [ -n "$session_name" ] && claude-smart-switch "$session_name" 2>/dev/null
  fi
fi
