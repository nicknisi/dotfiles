#!/usr/bin/env bash

# Agent-aware tmux session/pane dashboard
# Shows agent panes grouped by status with project path, tool info, and elapsed time
# Live pane preview on selection, Ctrl-R to refresh
#
# Keybindings:
#   Enter    вЂ” switch to selected pane/session
#   Ctrl-R   вЂ” refresh listing
#   Ctrl-N   вЂ” jump to next waiting agent (without closing dashboard)
#   Esc/q    вЂ” cancel

CLAUDE_DIR="$HOME/.cache/claude-status"
PI_DIR="$HOME/.cache/pi-status"

format_elapsed() {
  local secs=$1
  if [ "$secs" -lt 60 ]; then
    echo "${secs}s"
  elif [ "$secs" -lt 3600 ]; then
    local m=$((secs / 60))
    local s=$((secs % 60))
    [ "$s" -gt 0 ] && echo "${m}m ${s}s" || echo "${m}m"
  else
    local h=$((secs / 3600))
    local m=$((secs % 3600 / 60))
    [ "$m" -gt 0 ] && echo "${h}h ${m}m" || echo "${h}h"
  fi
}

# Get a useful location label for a pane
# Shows path relative to ~/Developer, or just the basename if shallow
pane_location() {
  local pane="$1" session="$2"
  local path
  path=$(tmux display-message -t "$pane" -p '#{pane_current_path}' 2>/dev/null)
  [ -z "$path" ] && return

  # Strip home and Developer prefix
  local short="${path/#$HOME\//}"
  short="${short/#Developer\//}"

  # If it's just the session name, not useful вЂ” show nothing
  [ "$short" = "$session" ] && return

  echo "$short"
}

# Preview: capture pane output for the selected item
# Called via fzf --preview with the selected line
show_preview() {
  local line="$1"
  local pane_id
  pane_id=$(echo "$line" | sed -n 's/.*\(%[0-9]*\).*/\1/p')

  if [ -n "$pane_id" ]; then
    # Agent pane вЂ” show captured output
    echo -e "\033[1mв”Ђв”Ђ Pane $pane_id в”Ђв”Ђ\033[0m"
    echo
    tmux capture-pane -p -t "$pane_id" -S -25 2>/dev/null
  else
    # Non-agent session вЂ” show window list
    local session
    session=$(echo "$line" | awk '{print $1}')
    [ -z "$session" ] && return
    echo -e "\033[1mв”Ђв”Ђ $session в”Ђв”Ђ\033[0m"
    echo
    tmux list-windows -t "$session" -F "  #{window_index}: #{window_name}  #{pane_current_path}" 2>/dev/null
  fi
}

# Generate the listing
generate_listing() {
  local now
  now=$(date +%s)

  local COMPLETED_DECAY=5
  local waiting=()
  local working=()
  local completed=()
  local idle=()
  local agent_sessions=()
  local w_count=0 a_count=0 c_count=0 i_count=0

  # Scan status files from both dirs
  for dir in "$CLAUDE_DIR" "$PI_DIR"; do
    [ -d "$dir" ] || continue
    for f in "$dir"/*.status; do
      [ -f "$f" ] || continue

      local state pane session tool ts
      state=$(jq -r '.state // "idle"' "$f" 2>/dev/null) || continue
      pane=$(jq -r '.pane // empty' "$f" 2>/dev/null)
      session=$(jq -r '.session // empty' "$f" 2>/dev/null)
      tool=$(jq -r '.tool // empty' "$f" 2>/dev/null)
      ts=$(jq -r '.ts // 0' "$f" 2>/dev/null)

      [ -n "$pane" ] || continue
      [ -n "$session" ] || continue

      # Verify pane exists (stale cleanup)
      if ! tmux display-message -t "$pane" -p '#{pane_id}' >/dev/null 2>&1; then
        rm -f "$f"
        continue
      fi

      agent_sessions+=("$session")

      # Location (only if it adds info beyond session name)
      local location
      location=$(pane_location "$pane" "$session")

      # Elapsed time
      local elapsed=""
      if [ "$ts" -gt 0 ] 2>/dev/null; then
        local diff=$((now - ts))
        [ "$diff" -ge 0 ] && elapsed=$(format_elapsed "$diff")
      fi

      # Decay completed в†’ idle
      if [ "$state" = "completed" ]; then
        local age=0
        [ "$ts" -gt 0 ] 2>/dev/null && age=$((now - ts))
        [ "$age" -ge "$COMPLETED_DECAY" ] && state="idle"
      fi

      # Tool display (truncate)
      local tool_display=""
      [ -n "$tool" ] && tool_display="${tool:0:14}"

      # Build detail string: tool + location context
      local detail=""
      if [ -n "$tool_display" ] && [ -n "$location" ]; then
        detail="$tool_display В· $location"
      elif [ -n "$tool_display" ]; then
        detail="$tool_display"
      elif [ -n "$location" ]; then
        detail="$location"
      fi

      # Build line: icon session pane_id detail elapsed
      # Pane ID embedded for extraction, dimmed
      local line
      case "$state" in
        waiting)
          w_count=$((w_count + 1))
          line=$(printf "\033[1;33mвЏі\033[0m %-16s \033[2m%-6s\033[0m  \033[33m%-28s\033[0m \033[1;33m%8s\033[0m" \
            "$session" "$pane" "$detail" "$elapsed")
          waiting+=("$line")
          ;;
        completed)
          c_count=$((c_count + 1))
          line=$(printf "\033[1;32mвњ“\033[0m  %-16s \033[2m%-6s\033[0m  \033[32m%-28s\033[0m \033[32m%8s\033[0m" \
            "$session" "$pane" "${detail:-done}" "$elapsed")
          completed+=("$line")
          ;;
        working)
          a_count=$((a_count + 1))
          line=$(printf "\033[38;5;208mвљЎ\033[0m %-16s \033[2m%-6s\033[0m  \033[2m%-28s\033[0m \033[2m%8s\033[0m" \
            "$session" "$pane" "$detail" "$elapsed")
          working+=("$line")
          ;;
        *)
          i_count=$((i_count + 1))
          line=$(printf "\033[2mВ·\033[0m  %-16s \033[2m%-6s\033[0m  \033[2m%-28s\033[0m \033[2m%8s\033[0m" \
            "$session" "$pane" "$detail" "$elapsed")
          idle+=("$line")
          ;;
      esac
    done
  done

  # Summary line
  local summary=""
  [ "$w_count" -gt 0 ] && summary+="\033[1;33m${w_count} waiting\033[0m  "
  [ "$c_count" -gt 0 ] && summary+="\033[1;32m${c_count} done\033[0m  "
  [ "$a_count" -gt 0 ] && summary+="\033[38;5;208m${a_count} working\033[0m  "
  [ "$i_count" -gt 0 ] && summary+="\033[2m${i_count} idle\033[0m  "
  if [ -n "$summary" ]; then
    echo -e "$summary"
    echo -e "\033[2mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
  fi

  # Agent panes: waiting в†’ completed в†’ working в†’ idle
  for l in "${waiting[@]}"; do echo -e "$l"; done
  for l in "${completed[@]}"; do echo -e "$l"; done
  for l in "${working[@]}"; do echo -e "$l"; done
  for l in "${idle[@]}"; do echo -e "$l"; done

  # Non-agent sessions
  local no_agent=()
  while IFS=: read -r name windows attached; do
    local has_agent=false
    for s in "${agent_sessions[@]}"; do
      [ "$s" = "$name" ] && { has_agent=true; break; }
    done
    $has_agent && continue

    local win_label="win"
    no_agent+=("$(printf "\033[2mВ·  %-16s        %-28s %s %s\033[0m" "$name" "" "$windows $win_label" "$attached")")
  done < <(tmux list-sessions -F "#{session_name}:#{session_windows}:#{?session_attached,(attached),}" 2>/dev/null)

  if [ ${#no_agent[@]} -gt 0 ]; then
    [ "$((w_count + c_count + a_count + i_count))" -gt 0 ] && echo -e "\033[2mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
    for l in "${no_agent[@]}"; do echo -e "$l"; done
  fi
}

# Self-invocation modes
case "${1:-}" in
  --generate)
    generate_listing
    exit 0
    ;;
  --preview)
    shift
    show_preview "$*"
    exit 0
    ;;
esac

SELF=$(realpath "$0")

# Run fzf with preview and reload
selected=$(generate_listing | fzf \
  --ansi \
  --no-sort \
  --header="enter: switch В· ctrl-r: refresh В· ctrl-n: next waiting В· esc: cancel" \
  --prompt="  " \
  --pointer="в–¶" \
  --preview="$SELF --preview {}" \
  --preview-window="right:45%:wrap" \
  --bind="ctrl-r:reload($SELF --generate)" \
  --bind="ctrl-n:execute-silent(claude-next)+abort" \
  --bind="j:down,k:up,q:cancel" \
  --layout=reverse \
  --info=inline \
  --margin=0 \
  --padding=0)

# Handle selection
if [ -n "$selected" ]; then
  # Skip separator/summary lines
  echo "$selected" | grep -qE 'в”Ѓв”Ѓв”Ѓ|в”Ђв”Ђв”Ђв”Ђв”Ђ| waiting| working| idle| done' && exit 0

  # Extract pane ID (%NN embedded in the line)
  pane_id=$(echo "$selected" | sed -n 's/.*\(%[0-9]*\).*/\1/p')

  if [ -n "$pane_id" ]; then
    # Agent pane вЂ” switch directly
    tmux switch-client -t "$pane_id" 2>/dev/null
  else
    # Non-agent session вЂ” smart switch (land on best agent pane if any)
    session_name=$(echo "$selected" | awk '{print $2}')
    [ -n "$session_name" ] && claude-smart-switch "$session_name" 2>/dev/null
  fi
fi
