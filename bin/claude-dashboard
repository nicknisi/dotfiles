#!/usr/bin/env bash

# Agent-aware tmux session/pane dashboard
# Shows agent panes grouped by status with project path, tool info, and elapsed time
# Live pane preview on selection, Ctrl-R to refresh
#
# Keybindings:
#   Enter    вЂ” switch to selected pane/session
#   Ctrl-R   вЂ” refresh listing
#   Ctrl-N   вЂ” jump to next waiting agent (without closing dashboard)
#   Esc/q    вЂ” cancel

. agent-status-lib

format_elapsed() {
  local secs=$1
  if [ "$secs" -lt 5 ]; then
    echo "now"
  elif [ "$secs" -lt 60 ]; then
    echo "${secs}s"
  elif [ "$secs" -lt 3600 ]; then
    echo "$(( secs / 60 ))m"
  elif [ "$secs" -lt 86400 ]; then
    echo "$(( secs / 3600 ))h"
  else
    echo "$(( secs / 86400 ))d"
  fi
}

# Get a useful location label for a pane
pane_location() {
  local pane="$1" session="$2"
  local path
  path=$(tmux display-message -t "$pane" -p '#{pane_current_path}' 2>/dev/null)
  [ -z "$path" ] && return

  local short="${path/#$HOME\//}"
  short="${short/#Developer\//}"

  [ "$short" = "$session" ] && return
  echo "$short"
}

# Git branch resolver with simple cache
declare -A _git_cache

pane_git_branch() {
  local pane="$1"
  local path
  path=$(tmux display-message -t "$pane" -p '#{pane_current_path}' 2>/dev/null)
  [ -z "$path" ] && return

  [ -n "${_git_cache[$path]+x}" ] && { echo "${_git_cache[$path]}"; return; }

  local branch
  branch=$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null)
  _git_cache[$path]="${branch:-}"
  [ -n "$branch" ] && echo "$branch"
}

# Compact port hint: вЊЃ3000 or вЊЃ3000+2
format_ports() {
  local raw="$1"
  [ -z "$raw" ] && return
  local first="${raw%%,*}"
  local rest="${raw#*,}"
  if [ "$rest" = "$raw" ]; then
    echo "вЊЃ${first}"
  else
    local count=1
    local tmp="$rest"
    while [ "$tmp" != "${tmp#*,}" ]; do
      count=$((count + 1))
      tmp="${tmp#*,}"
    done
    count=$((count + 1))
    echo "вЊЃ${first}+${count}"
  fi
}

# Preview: capture pane output for the selected item
show_preview() {
  local line="$1"
  local pane_id
  pane_id=$(echo "$line" | sed -n 's/.*\(%[0-9]*\).*/\1/p')

  if [ -n "$pane_id" ]; then
    echo -e "\033[1mв”Ђв”Ђ Pane $pane_id в”Ђв”Ђ\033[0m"
    echo
    tmux capture-pane -p -t "$pane_id" -S -25 2>/dev/null
  else
    local session
    session=$(echo "$line" | awk '{print $1}')
    [ -z "$session" ] && return
    echo -e "\033[1mв”Ђв”Ђ $session в”Ђв”Ђ\033[0m"
    echo
    tmux list-windows -t "$session" -F "  #{window_index}: #{window_name}  #{pane_current_path}" 2>/dev/null
  fi
}

generate_listing() {
  local now
  now=$(date +%s)

  local waiting=()
  local working=()
  local completed=()
  local stale_lines=()
  local idle=()
  local agent_sessions=()
  local w_count=0 a_count=0 c_count=0 s_count=0 i_count=0

  # Build port lookup for all panes
  declare -A _pane_ports
  while read -r p port; do
    _pane_ports[$p]="${_pane_ports[$p]:+${_pane_ports[$p]},}$port"
  done < <(claude-ports 2>/dev/null)

  # Scan status files from all registered dirs
  while IFS= read -r dir; do
    [ -d "$dir" ] || continue
    for f in "$dir"/*.status; do
      [ -f "$f" ] || continue

      local state pane session tool ts
      state=$(jq -r '.state // "idle"' "$f" 2>/dev/null) || continue
      pane=$(jq -r '.pane // empty' "$f" 2>/dev/null)
      session=$(jq -r '.session // empty' "$f" 2>/dev/null)
      tool=$(jq -r '.tool // empty' "$f" 2>/dev/null)
      ts=$(jq -r '.ts // 0' "$f" 2>/dev/null)

      [ -n "$pane" ] || continue
      [ -n "$session" ] || continue

      # Verify pane exists (stale cleanup)
      if ! tmux display-message -t "$pane" -p '#{pane_id}' >/dev/null 2>&1; then
        rm -f "$f"
        continue
      fi

      agent_sessions+=("$session")

      # Location
      local location
      location=$(pane_location "$pane" "$session")

      # Elapsed time
      local elapsed=""
      if [ "$ts" -gt 0 ] 2>/dev/null; then
        local diff=$((now - ts))
        [ "$diff" -ge 0 ] && elapsed=$(format_elapsed "$diff")
      fi

      # Compute effective state
      state=$(agent_effective_state "$state" "${ts:-0}" "$now")

      # Build detail: location, then branch, then ports
      local detail=""
      [ -n "$location" ] && detail="$location"

      # Git branch (suppress main/master, truncate)
      local git_branch
      git_branch=$(pane_git_branch "$pane")
      if [ -n "$git_branch" ] && [ "$git_branch" != "main" ] && [ "$git_branch" != "master" ]; then
        detail="${detail:+$detail В· }${git_branch:0:20}"
      fi

      # Port info (compact)
      local ports="${_pane_ports[$pane]:-}"
      if [ -n "$ports" ]; then
        local port_hint
        port_hint=$(format_ports "$ports")
        detail="${detail:+$detail В· }$port_hint"
      fi

      # Truncate detail
      detail="${detail:0:30}"

      # Icon: unseen в—Џ replaces state icon, seen uses state icon
      local icon mark
      if agent_is_unseen "$f"; then
        mark="\033[1;33mв—Џ\033[0m"
      else
        mark=" "
      fi

      # Pane ID embedded at end (dimmed, for extraction by fzf handler)
      local pane_tag="\033[2;30m$pane\033[0m"

      local line
      case "$state" in
        waiting)
          w_count=$((w_count + 1))
          line=$(printf "%b \033[1;33mвЏі\033[0m %-14s \033[33m%-30s\033[0m \033[1;33m%5s\033[0m  %b" \
            "$mark" "$session" "$detail" "$elapsed" "$pane_tag")
          waiting+=("$line")
          ;;
        completed)
          c_count=$((c_count + 1))
          line=$(printf "%b \033[1;32mвњ“\033[0m  %-14s \033[32m%-30s\033[0m \033[32m%5s\033[0m  %b" \
            "$mark" "$session" "${detail:-done}" "$elapsed" "$pane_tag")
          completed+=("$line")
          ;;
        working)
          a_count=$((a_count + 1))
          line=$(printf "  \033[38;5;208mвљЎ\033[0m %-14s \033[2m%-30s\033[0m \033[2m%5s\033[0m  %b" \
            "$session" "$detail" "$elapsed" "$pane_tag")
          working+=("$line")
          ;;
        stale)
          s_count=$((s_count + 1))
          line=$(printf "  \033[2mвљ \033[0m  %-14s \033[2;33m%-30s\033[0m \033[2;33m%5s\033[0m  %b" \
            "$session" "${detail:-stale}" "$elapsed" "$pane_tag")
          stale_lines+=("$line")
          ;;
        *)
          i_count=$((i_count + 1))
          line=$(printf "  \033[2mВ·\033[0m  %-14s \033[2m%-30s\033[0m \033[2m%5s\033[0m  %b" \
            "$session" "$detail" "$elapsed" "$pane_tag")
          idle+=("$line")
          ;;
      esac
    done
  done < <(agent_status_dirs)

  # Summary line
  local summary=""
  [ "$w_count" -gt 0 ] && summary+="\033[1;33m${w_count} waiting\033[0m  "
  [ "$c_count" -gt 0 ] && summary+="\033[1;32m${c_count} done\033[0m  "
  [ "$a_count" -gt 0 ] && summary+="\033[38;5;208m${a_count} working\033[0m  "
  [ "$s_count" -gt 0 ] && summary+="\033[2;33m${s_count} stale\033[0m  "
  [ "$i_count" -gt 0 ] && summary+="\033[2m${i_count} idle\033[0m  "
  if [ -n "$summary" ]; then
    echo -e "$summary"
    echo -e "\033[2mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
  fi

  # Agent panes: waiting в†’ completed в†’ working в†’ stale в†’ idle
  for l in "${waiting[@]}"; do echo -e "$l"; done
  for l in "${completed[@]}"; do echo -e "$l"; done
  for l in "${working[@]}"; do echo -e "$l"; done
  for l in "${stale_lines[@]}"; do echo -e "$l"; done
  for l in "${idle[@]}"; do echo -e "$l"; done

  # Non-agent sessions
  local no_agent=()
  while IFS=: read -r name windows attached; do
    local has_agent=false
    for s in "${agent_sessions[@]}"; do
      [ "$s" = "$name" ] && { has_agent=true; break; }
    done
    $has_agent && continue

    no_agent+=("$(printf "\033[2m   В·  %-14s %-30s %sw %s\033[0m" "$name" "" "$windows" "$attached")")
  done < <(tmux list-sessions -F "#{session_name}:#{session_windows}:#{?session_attached,(attached),}" 2>/dev/null)

  if [ ${#no_agent[@]} -gt 0 ]; then
    [ "$((w_count + c_count + a_count + s_count + i_count))" -gt 0 ] && echo -e "\033[2mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\033[0m"
    for l in "${no_agent[@]}"; do echo -e "$l"; done
  fi
}

# Self-invocation modes
case "${1:-}" in
  --generate)
    generate_listing
    exit 0
    ;;
  --preview)
    shift
    show_preview "$*"
    exit 0
    ;;
esac

SELF=$(realpath "$0")

# Run fzf with preview and reload
selected=$(generate_listing | fzf \
  --ansi \
  --no-sort \
  --header="enter: switch В· ctrl-r: refresh В· ctrl-n: next waiting В· esc: cancel" \
  --prompt="  " \
  --pointer="в–¶" \
  --preview="$SELF --preview {}" \
  --preview-window="right:45%:wrap" \
  --bind="ctrl-r:reload($SELF --generate)" \
  --bind="ctrl-n:execute-silent(claude-next)+abort" \
  --bind="j:down,k:up,q:cancel" \
  --layout=reverse \
  --info=inline \
  --margin=0 \
  --padding=0)

# Handle selection
if [ -n "$selected" ]; then
  # Skip separator/summary lines
  echo "$selected" | grep -qE 'в”Ѓв”Ѓв”Ѓ|в”Ђв”Ђв”Ђв”Ђ| waiting| working| idle| done' && exit 0

  # Extract pane ID (%NN embedded in the line)
  pane_id=$(echo "$selected" | sed -n 's/.*\(%[0-9]*\).*/\1/p')

  if [ -n "$pane_id" ]; then
    # Agent pane вЂ” switch directly
    tmux switch-client -t "$pane_id" 2>/dev/null
  else
    # Non-agent session вЂ” smart switch
    session_name=$(echo "$selected" | awk '{print $2}')
    [ -n "$session_name" ] && claude-smart-switch "$session_name" 2>/dev/null
  fi
fi
