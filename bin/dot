#!/usr/bin/env bash

set -Eeuo pipefail
trap cleanup SIGINT SIGTERM ERR EXIT

cleanup() {
  trap - SIGINT SIGTERM ERR EXIT
}

command_name=$(basename "${BASH_SOURCE[0]}")
script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" &>/dev/null && pwd -P)
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

if [[ -f "$DOTFILES/bin/lib/common.sh" ]]; then
  source "$DOTFILES/bin/lib/common.sh"
else
  echo "Error: Unable to source common.sh"
  exit 1
fi

find_commands() {
  IFS=: read -ra path_dirs <<<"$PATH"
  for dir in "${path_dirs[@]}"; do
    # skip if the directory doesn't exist or isn't readable
    [[ ! -d "$dir" ]] && continue
    for cmd in "$dir"/dot-*; do
      [[ -f "$cmd" && -x "$cmd" ]] || continue
      basename "$cmd" | sed 's/^dot-//'
    done
  done | sort -u
}

usage() {
  cat <<EOF
  $(fmt_key "Usage:") $(fmt_cmd "$command_name") $(fmt_value "<command> [subcommand] [options]")

Dotfiles management script.

$(fmt_key "Available Commands:")
    help                          Show this help message
    clean                         Clean up broken symlinks
    backup                        Backup dotfiles
        -d, --directory <dir>   Backup directory (default: ~/dotfiles-backup)
    link [pkg]                    Link packages (default: all)
        clean                     Remove broken symlinks
            -n, --dry-run         Preview without removing
    unlink [pkg]                  Unlink packages (default: all)
EOF

  echo -e "\nExternal commands:"

  find_commands | while read -r cmd; do
    # Get the description from the script if available
    description=$(grep "^# Description:" "$(which "dot-$cmd")" 2>/dev/null | cut -d: -f2- | sed 's/^[[:space:]]*//' || echo "No description available")
    printf "    $(fmt_cmd "%-12s") %s\n" "$cmd" "$description"
  done
}

cmd_clean() {
  links=(
    ".zshrc" ".zshenv" ".zprofile" ".zsh_aliases"
    ".zsh_functions" ".zsh_prompt" ".config/aerospace"
    ".config/git" ".config/karabiner" ".config/kitty"
    ".config/lazygit" ".config/nvim" ".config/ripgrep"
    ".config/tmux" ".config/wezterm" ".config/zsh"
  )

  fmt_title_underline "Cleaning up broken legacy symlinks..."

  for link in "${links[@]}"; do
    path_link="$HOME/$link"
    if [ -L "$path_link" ] && [ ! -e "$path_link" ]; then
      log_success "Removing Broken symbolic link: $path_link"
      rm "$path_link"
    else
      log_info "Link to $path_link not found or is not broken. Skipping..."
    fi
  done

  # Clean up broken symlinks from home directory
  if [ -d "$DOTFILES/home" ]; then
    shopt -s dotglob
    for entry in "$DOTFILES/home"/*; do
      [ -e "$entry" ] || continue
      local name="$(basename "$entry")"
      [[ "$name" == ".DS_Store" ]] && continue
      local target_path="$HOME/$name"
      if [ -L "$target_path" ] && [ ! -e "$target_path" ]; then
        log_success "Removing broken symbolic link: $target_path"
        rm "$target_path"
      fi
    done
    shopt -u dotglob
  fi

  echo -e
  log_success "Done."
}

cmd_backup() {
  local backup_dir="$HOME/dotfiles-backup"
  local verbose=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -d | --directory)
      if [[ -n "${2:-}" ]]; then
        backup_dir="$2"
        shift 2
      else
        log_error "Missing backup directory"
        exit 1
      fi
      ;;
    -v | --verbose)
      verbose=true
      shift
      ;;
    *)
      log_error "Unknown argument: $1"
      exit 1
      ;;
    esac
  done

  # Expand ~ in backup_dir
  backup_dir="${backup_dir/#\~/$HOME}"

  local timestamp=$(date +%Y%m%d_%H%M%S)
  local backup_path="${backup_dir}/dotfiles_backup_${timestamp}"

  log_info "Creating backup in: $backup_path"

  files_to_backup=(
    ".zshrc"
    ".zprofile"
    ".zsh_aliases"
    ".zsh_functions"
    ".zsh_prompt"
    ".config/aerospace"
    ".config/git"
    ".config/ghostty"
    ".config/karabiner"
    ".config/kitty"
    ".config/lazygit"
    ".config/nvim"
    ".config/ripgrep"
    ".config/tmux"
    ".config/wezterm"
    ".config/zsh"
  )

  # Add home directory entries to backup
  if [ -d "$DOTFILES/home" ]; then
    shopt -s dotglob
    for entry in "$DOTFILES/home"/*; do
      [ -e "$entry" ] || continue
      local name="$(basename "$entry")"
      [[ "$name" == ".DS_Store" ]] && continue
      files_to_backup+=("$name")
    done
    shopt -u dotglob
  fi

  tmpfile=$(mktemp)
  trap 'rm -f "$tmpfile"' EXIT

  for file in "${files_to_backup[@]}"; do
    src_path="${HOME}/${file}"
    if [[ -L "$src_path" ]]; then
      [[ "$verbose" == true ]] && log_info "Skipping symlink: $file"
      continue
    elif [[ -e "$src_path" ]]; then
      echo "$file" >>"$tmpfile"
      [[ "$verbose" == true ]] && log_info "Found: $file"
    else
      log_warning "File not found: $src_path"
    fi
  done

  if [[ -s "$tmpfile" ]]; then
    tar -czf "${backup_path}.tar.gz" -C "$HOME" -T "$tmpfile" || {
      log_error "Failed to create backup archive"
      exit 1
    }

    if [[ "$verbose" == true ]]; then
      log_info "Archive contents:"
      tar -tvf "${backup_path}.tar.gz" | while read -r line; do
        log_info "$line"
      done
    fi

    log_success "Backup created successfully"
  else
    log_warning "No files to backup"
  fi
}

# ── Symlink helpers ──────────────────────────────────────────────

STAT_LINKED=0
STAT_UNLINKED=0
STAT_UNCHANGED=0
STAT_SKIPPED=0

stat_reset() { STAT_LINKED=0; STAT_UNLINKED=0; STAT_UNCHANGED=0; STAT_SKIPPED=0; }

do_link() {
  local src="$1" target="$2" label="$3"
  local display="~${target#"$HOME"}"

  if [ -L "$target" ]; then
    if [ "$(readlink "$target")" = "$src" ]; then
      STAT_UNCHANGED=$((STAT_UNCHANGED + 1))
      return 0
    fi
    printf "  ${YELLOW}⚠ %-20s${RESET} ${DIM}symlink → wrong target${RESET}\n" "$label"
    STAT_SKIPPED=$((STAT_SKIPPED + 1))
  elif [ -e "$target" ]; then
    printf "  ${YELLOW}⚠ %-20s${RESET} ${DIM}exists (not a symlink)${RESET}\n" "$label"
    STAT_SKIPPED=$((STAT_SKIPPED + 1))
  else
    ln -s "$src" "$target"
    printf "  ${GREEN}+ %-20s${RESET} ${DIM}→ %s${RESET}\n" "$label" "$display"
    STAT_LINKED=$((STAT_LINKED + 1))
  fi
}

do_unlink() {
  local target="$1" label="$2"
  local display="~${target#"$HOME"}"

  if [ -L "$target" ]; then
    rm "$target"
    printf "  ${RED}- %-20s${RESET} ${DIM}%s${RESET}\n" "$label" "$display"
    STAT_UNLINKED=$((STAT_UNLINKED + 1))
  elif [ -e "$target" ]; then
    printf "  ${YELLOW}⚠ %-20s${RESET} ${DIM}not a symlink${RESET}\n" "$label"
    STAT_SKIPPED=$((STAT_SKIPPED + 1))
  else
    STAT_UNCHANGED=$((STAT_UNCHANGED + 1))
  fi
}

print_summary() {
  local operation="$1"
  local parts=()

  if [ "$operation" = "link" ]; then
    [ "$STAT_LINKED" -gt 0 ] && parts+=("$(printf "${GREEN}%d linked${RESET}" "$STAT_LINKED")")
  else
    [ "$STAT_UNLINKED" -gt 0 ] && parts+=("$(printf "${RED}%d unlinked${RESET}" "$STAT_UNLINKED")")
  fi
  [ "$STAT_SKIPPED" -gt 0 ] && parts+=("$(printf "${YELLOW}%d skipped${RESET}" "$STAT_SKIPPED")")
  [ "$STAT_UNCHANGED" -gt 0 ] && parts+=("$(printf "${DIM}%d unchanged${RESET}" "$STAT_UNCHANGED")")

  if [ ${#parts[@]} -gt 0 ]; then
    local IFS=", "
    printf "\n  ${BOLD}${SUCCESS_ICON}${RESET} %s\n" "${parts[*]}"
  fi
}

# ── Clean broken symlinks ───────────────────────────────────────

cmd_link_clean() {
  local dry_run=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -n | --dry-run) dry_run=true; shift ;;
    *) log_error "Unknown argument: $1"; exit 1 ;;
    esac
  done

  printf "\n  ${BOLD}dot link clean${RESET}"
  [ "$dry_run" = true ] && printf " ${DIM}(dry run)${RESET}"
  printf "\n\n"

  local broken_count=0

  # Check config directory symlinks
  if [ -d "$CONFIG_HOME" ]; then
    while IFS= read -r -d '' link; do
      if [ -L "$link" ] && [ ! -e "$link" ]; then
        broken_count=$((broken_count + 1))
        local display="~${link#"$HOME"}"
        if [ "$dry_run" = true ]; then
          printf "  ${YELLOW}⚠ %s${RESET}\n" "$display"
        else
          printf "  ${RED}- %s${RESET}\n" "$display"
          rm "$link"
        fi
      fi
    done < <(find "$CONFIG_HOME" -type l -print0 2>/dev/null || true)
  fi

  # Check home directory symlinks
  if [ -d "$DOTFILES/home" ]; then
    shopt -s dotglob
    for entry in "$DOTFILES/home"/*; do
      [ -e "$entry" ] || continue
      local name="$(basename "$entry")"
      [[ "$name" == ".DS_Store" ]] && continue
      local target_path="$HOME/$name"
      if [ -L "$target_path" ] && [ ! -e "$target_path" ]; then
        local link_target
        link_target=$(readlink "$target_path")
        if [[ "$link_target" == "$DOTFILES"* ]]; then
          broken_count=$((broken_count + 1))
          if [ "$dry_run" = true ]; then
            printf "  ${YELLOW}⚠ ~/%s${RESET}\n" "$name"
          else
            printf "  ${RED}- ~/%s${RESET}\n" "$name"
            rm "$target_path"
          fi
        fi
      fi
    done
    shopt -u dotglob
  fi

  echo
  if [ "$broken_count" -eq 0 ]; then
    printf "  ${BOLD}${SUCCESS_ICON}${RESET} ${DIM}no broken symlinks${RESET}\n"
  elif [ "$dry_run" = true ]; then
    printf "  ${BOLD}${WARNING_ICON}${RESET} ${YELLOW}%d broken symlink(s)${RESET} ${DIM}— run without --dry-run to remove${RESET}\n" "$broken_count"
  else
    printf "  ${BOLD}${SUCCESS_ICON}${RESET} ${GREEN}removed %d broken symlink(s)${RESET}\n" "$broken_count"
  fi
  echo
}

# ── Link / Unlink ───────────────────────────────────────────────

cmd_link() {
  local operation="$1"
  shift

  # Handle 'dot link clean' — pass remaining args through
  if [ "$operation" = "link" ] && [[ "${1:-}" == "clean" ]]; then
    shift
    cmd_link_clean "$@"
    return
  fi

  local pkg="all"

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -v | --verbose) shift ;; # accepted for backwards compat, ignored
    -*) log_error "Unknown option: $1"; exit 1 ;;
    *) pkg="$1"; shift ;;
    esac
  done

  stat_reset

  # Title
  local action_word
  [ "$operation" = "link" ] && action_word="link" || action_word="unlink"

  if [ "$pkg" = "all" ]; then
    printf "\n  ${BOLD}dot %s${RESET}\n\n" "$action_word"
  else
    printf "\n  ${BOLD}dot %s${RESET} ${DIM}─${RESET} %s\n\n" "$action_word" "$pkg"
  fi

  if [ "$pkg" = "all" ]; then
    # Config packages
    for config in "$DOTFILES/config"/*; do
      [ -d "$config" ] || continue
      local name
      name="$(basename "$config")"
      if [ "$operation" = "link" ]; then
        do_link "$config" "$CONFIG_HOME/$name" "$name"
      else
        do_unlink "$CONFIG_HOME/$name" "$name"
      fi
    done

    # Home entries
    if [ -d "$DOTFILES/home" ]; then
      shopt -s dotglob
      for entry in "$DOTFILES/home"/*; do
        [ -e "$entry" ] || continue
        local name
        name="$(basename "$entry")"
        [[ "$name" == ".DS_Store" ]] && continue
        if [ "$operation" = "link" ]; then
          do_link "$entry" "$HOME/$name" "$name"
        else
          do_unlink "$HOME/$name" "$name"
        fi
      done
      shopt -u dotglob
    fi
  else
    # Specific package — check config/ first, then home/
    if [ -d "$DOTFILES/config/$pkg" ]; then
      if [ "$operation" = "link" ]; then
        do_link "$DOTFILES/config/$pkg" "$CONFIG_HOME/$pkg" "$pkg"
      else
        do_unlink "$CONFIG_HOME/$pkg" "$pkg"
      fi
    elif [ -e "$DOTFILES/home/.$pkg" ] || [ -e "$DOTFILES/home/$pkg" ]; then
      local name="$pkg"
      [ -e "$DOTFILES/home/.$pkg" ] && name=".$pkg"
      if [ "$operation" = "link" ]; then
        do_link "$DOTFILES/home/$name" "$HOME/$name" "$name"
      else
        do_unlink "$HOME/$name" "$name"
      fi
    else
      log_error "Package \"$pkg\" not found in config/ or home/"
      return 1
    fi
  fi

  print_summary "$operation"
  echo
}

main() {
  if [ $# -lt 1 ]; then
    usage
    exit 0
  fi

  cmd="$1"
  shift || true
  subcmd="${1:-all}"

  case "$cmd" in
  help)
    usage
    ;;
  clean)
    cmd_clean "$@"
    ;;
  backup)
    cmd_backup "$@"
    ;;
  link)
    cmd_link "link" "$@"
    ;;
  unlink)
    cmd_link "unlink" "$@"
    ;;
  *)
    if command -v "dot-$cmd" >/dev/null 2>&1; then
      "dot-$cmd" "$@"
    else
      log_error "Unknown command: $cmd"
      usage
      exit 1
    fi
    ;;
  esac
}

main "$@"
