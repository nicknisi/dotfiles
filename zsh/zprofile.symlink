# .zprofile is sourced on login shells and before .zshrc. As a general rule, it should not change the
# shell environment at all.

# Linuxbrew shellenv (WSL2 target). macOS Homebrew paths removed — this repo
# is Linux/WSL-only per AGENTS.md.
if [[ -d ~/.linuxbrew ]]; then
    eval "$(~/.linuxbrew/bin/brew shellenv)"
elif [[ -d /home/linuxbrew/.linuxbrew ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
